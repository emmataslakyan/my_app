<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    android:layout_marginHorizontal="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gradient Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/header_gradient"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Text Size"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Options -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- Font Size -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Font Size"
                    android:textColor="#222222"
                    android:textSize="15sp" />
                <Spinner
                    android:id="@+id/spinnerFontSize"
                    android:layout_width="130dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/modern_input_bg" />
            </RelativeLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

            <!-- Name Size -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Name Size"
                    android:textColor="#222222"
                    android:textSize="15sp" />
                <Spinner
                    android:id="@+id/spinnerNameSize"
                    android:layout_width="130dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/modern_input_bg" />
            </RelativeLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

            <!-- Heading Size -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Heading Size"
                    android:textColor="#222222"
                    android:textSize="15sp" />
                <Spinner
                    android:id="@+id/spinnerHeadingSize"
                    android:layout_width="130dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/modern_input_bg" />
            </RelativeLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

            <!-- Font Style -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Font Style"
                    android:textColor="#222222"
                    android:textSize="15sp" />
                <Spinner
                    android:id="@+id/spinnerFontStyle"
                    android:layout_width="130dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/modern_input_bg" />
            </RelativeLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

            <!-- Line Spacing -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Line Spacing"
                    android:textColor="#222222"
                    android:textSize="15sp" />
                <Spinner
                    android:id="@+id/spinnerLineSpacing"
                    android:layout_width="130dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/modern_input_bg" />
            </RelativeLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

            <!-- Text Alignment -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Text Alignment"
                    android:textColor="#222222"
                    android:textSize="15sp" />
                <Spinner
                    android:id="@+id/spinnerAlignment"
                    android:layout_width="130dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/modern_input_bg" />
            </RelativeLayout>

            <!-- Apply Button -->
            <Button
                android:id="@+id/btnApply"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/gradient_button_rounded"
                android:text="Apply"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>