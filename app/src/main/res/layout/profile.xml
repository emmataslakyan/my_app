<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:id="@+id/main"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="@drawable/glass_card"
android:fillViewport="true"
android:scrollbars="none">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- ═══════════════════════════════════════════
         Toolbar
    ════════════════════════════════════════════ -->
    <include layout="@layout/activity_toolbar" />

    <!-- ═══════════════════════════════════════════
         Avatar + Name + Email header
    ════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="16dp">

        <!-- Avatar with edit overlay -->
        <FrameLayout
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/profile_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/profile"
                android:scaleType="centerCrop"
                android:contentDescription="User Avatar" />

            <!-- Edit badge -->
            <ImageView
                android:id="@+id/btn_change_photo"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/buttonn"
                android:contentDescription="Change photo"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <TextView
            android:id="@+id/profile_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1D1133"
            android:layout_marginTop="14dp" />

        <TextView
            android:id="@+id/profile_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="user@email.com"
            android:textSize="14sp"
            android:textColor="#120A1F"
            android:alpha="0.6"
            android:layout_marginTop="4dp" />

        <!-- Edit Profile button -->
        <Button
            android:id="@+id/btn_edit_profile"
            android:layout_width="160dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/buttonn"
            android:text="Edit Profile"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         Personal Info Card (read-only summary)
    ════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="14dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        android:background="@drawable/glass_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/person"
                    android:contentDescription=""
                    app:tint="#7E0D0D0F" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Personal Info"
                    android:textColor="#431772"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Address -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_mapmode"
                    android:contentDescription=""
                    app:tint="#888888" />
                <TextView
                    android:id="@+id/tv_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="—"
                    android:textColor="#444444"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Phone -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_call"
                    android:contentDescription=""
                    app:tint="#888888" />
                <TextView
                    android:id="@+id/tv_phone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="—"
                    android:textColor="#444444"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- e-mail -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/email"
                    android:contentDescription=""
                    app:tint="#888888" />
                <TextView
                    android:id="@+id/email_input"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="—"
                    android:textColor="#444444"
                    android:textSize="14sp" />
            </LinearLayout>
            <!-- LinkedIn -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/language"
                    android:contentDescription=""
                    app:tint="#888888" />
                <TextView
                    android:id="@+id/tv_linkedin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="—"
                    android:textColor="#444444"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Summary -->
            <TextView
                android:id="@+id/tv_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="#666666"
                android:textSize="13sp"
                android:lineSpacingExtra="3dp"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ═══════════════════════════════════════════
         Education Card
    ════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="14dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        android:background="@drawable/glass_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section header + Add button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:contentDescription=""
                    app:tint="#6133B8" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Education"
                    android:textColor="#431772"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_add_education"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_input_add"
                    android:contentDescription="Add education"
                    app:tint="#6133B8" />
            </LinearLayout>

            <!-- Education entries injected here programmatically -->
            <LinearLayout
                android:id="@+id/container_education"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/tv_edu_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap + to add your education — it will auto-fill into every new resume."
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="8dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ═══════════════════════════════════════════
         Documents & Certificates Card
    ════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="14dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        android:background="@drawable/glass_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section header + Upload button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:contentDescription=""
                    app:tint="#6133B8" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Documents &amp; Certificates"
                    android:textColor="#431772"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_upload_document"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_input_add"
                    android:contentDescription="Upload document"
                    app:tint="#6133B8" />
            </LinearLayout>

            <!-- Document list injected here programmatically -->
            <LinearLayout
                android:id="@+id/container_documents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/tv_docs_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Upload your CV, certificates, or diplomas for quick access."
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="8dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ═══════════════════════════════════════════
         Logout Button
    ════════════════════════════════════════════ -->
    <Button
        android:id="@+id/logout_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:text="@string/btn_logout"
        android:textColor="@android:color/white"
        android:textStyle="bold" />

</LinearLayout>
</ScrollView>