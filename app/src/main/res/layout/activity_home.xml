<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/glass_card">

    <!-- ══════════════════════════════════════════════
         HEADER
         ══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--  ★ GRADIENT TARGET: dashboardTitle  -->
        <TextView
            android:id="@+id/dashboard_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"
            android:text="@string/dashboard_title"
            android:textColor="#280F4F"
            android:textSize="50sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_language_menu"
            android:layout_width="50dp"
            android:layout_height="45dp"
            android:alpha="0.4"
            android:contentDescription="Language settings"
            android:src="@drawable/language"
            app:tint="#2A0F51" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════
         MAIN SCROLL BODY
         ══════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="4dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <!--  ★ GRADIENT TARGET: continueLabel  -->
            <TextView
                android:id="@+id/continueLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:fontFamily="sans-serif-medium"
                android:text="Continue Building"
                android:textColor="#051256"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- ════════════════════════════════════════
                 HERO RESUME CARD (glass)
                 ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/resume_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/glass_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:visibility="gone"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                tools:visibility="visible">

                <LinearLayout

                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <!-- Resume thumbnail -->
                    <LinearLayout
                        android:layout_width="90dp"
                        android:layout_height="118dp"
                        android:background="@drawable/glass_card"

                        android:gravity="top|center_horizontal"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="8dp">

                        <View
                            android:layout_width="31dp"
                            android:layout_height="31dp"
                            android:background="@drawable/profile2"
                            android:backgroundTint="#A096B8" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginTop="8dp"
                            android:background="#D6C8EF" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginTop="4dp"
                            android:background="#D5CEEF" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginTop="4dp"
                            android:background="#D5CEEF" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginTop="4dp"
                            android:background="#D5CEEF" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:layout_marginTop="4dp"
                            android:background="#D5CEEF" />

                        <View
                            android:layout_width="26dp"
                            android:layout_height="2dp"
                            android:layout_marginTop="4dp"
                            android:background="#E4E0F5" />
                    </LinearLayout>

                    <!-- Info column -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!--  ★ GRADIENT TARGET: resumeCardTitle  -->
                        <TextView
                            android:id="@+id/resume_card_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="#051256"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="Active Resume draft" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Active draft"
                            android:textColor="#120F0F"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/resume_card_days"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:textColor="#000000"
                            android:textSize="11sp"
                            tools:text="Progress – 12 days" />

                        <ProgressBar
                            android:id="@+id/resume_progress_bar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="14dp"
                            android:max="100"
                            android:progress="40"
                            android:progressBackgroundTint="#DDD6F0"
                            android:progressTint="#46287A" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_view_resume"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:minHeight="0dp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="View resume"
                            android:textColor="#46287A"
                            android:textSize="11sp"
                            app:cornerRadius="20dp"
                            app:strokeColor="#46287A" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Empty state spacer -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/no_resume_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/glass_card"
                android:visibility="visible"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp" />

            <!-- ════════════════════════════════════════
                 SPARK ASSISTANT PILL
                 ════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/ai_section"
                android:layout_width="wrap_content"
                android:layout_height="74dp"
                android:layout_marginBottom="28dp"
                android:background="@drawable/buttonn"
                android:clickable="true"
                android:elevation="10dp"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingEnd="22dp">

                <LinearLayout
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/s"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:contentDescription="Spark Assistant"
                        android:src="@drawable/ai"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <!--  ★ GRADIENT TARGET: sparkAssistantText  -->
                <TextView
                    android:id="@+id/sparkAssistantText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/spark_assistant"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="›"
                    android:textColor="#BBA8DE"
                    android:textSize="30sp" />
            </LinearLayout>

            <!-- ════════════════════════════════════════
                 RESUME BUILDER ROW
                 ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/resume_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="74dp"
                    android:background="@drawable/glass_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="50dp"

                        android:contentDescription="Resume Builder Icon"
                        android:src="@drawable/resume"
                        app:tint="#46287A" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/resume_builder"
                        android:textColor="#2C1153"
                        android:textSize="20sp"

                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="›"
                        android:textColor="#46287A"
                        android:textSize="22sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/opp_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="74dp"
                    android:background="@drawable/glass_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="50dp"

                        android:contentDescription="Resume Builder Icon"
                        android:src="@drawable/opp"
                        app:tint="#46287A" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/discover_opps"
                        android:textColor="#2C1153"
                        android:textSize="20sp"

                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="›"
                        android:textColor="#46287A"
                        android:textSize="22sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- ════════════════════════════════════════
                 DISCOVER OPPORTUNITIES ROW
                 ════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/opportunities_section"
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!--  ★ GRADIENT TARGET: discoverLabel  -->
                <TextView
                    android:id="@+id/discoverLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/pdf_tools"
                    android:textColor="#051256"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="›"
                    android:textColor="#46287A"
                    android:textSize="22sp" />
            </LinearLayout>

            <!-- ════════════════════════════════════════
                 DISCOVERY GRID — 3 glass tiles
                 ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:weightSum="3">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tile_peer"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"

                        android:padding="8dp">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:contentDescription="Peer Advisory"
                            android:background="@drawable/glass_card"

                            android:src="@drawable/merge"
                            app:tint="#46287A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Merge"
                            android:textColor="#051256"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tile_split"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/glass_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"

                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="Financial Development"
                            android:src="@drawable/split"
                            android:background="@drawable/glass_card"
                            app:tint="#46287A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Split"
                            android:textColor="#051256"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tile_compress"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/glass_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="27dp"
                            android:layout_height="27dp"
                            android:contentDescription="Compress"
                            android:src="@drawable/compress"
                            android:background="@drawable/glass_card"
                            app:tint="#46287A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Compress"
                            android:textColor="#051256"
                            android:textSize="11sp" />
                    </LinearLayout>


                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>



            <!-- Empty state spacer -->
            <!-- ════════════════════════════════════════
                PROFILE SECTION
                ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profile_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/glass_card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="361dp"
                    android:layout_height="74dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:contentDescription="Profile Picture"
                        android:src="@drawable/profile"
                        android:tint="#290F4D"
                        app:shapeAppearanceOverlay="@style/CircleImage" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/my_profile"
                            android:textColor="#051256"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_sub"
                            android:textColor="#757575"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="›"
                        android:textColor="#46287A"
                        android:textSize="22sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>