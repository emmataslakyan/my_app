<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:id="@+id/previewName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#000000"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/previewContactInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#333333"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:id="@+id/sectionEducation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FORMAL EDUCATION"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="12sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#000000" android:layout_marginTop="1dp" />

            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp">
                <TextView
                    android:id="@+id/previewEduName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="#000000" />
                <TextView
                    android:id="@+id/previewEduLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:textStyle="bold"
                    android:textSize="11sp" />
            </RelativeLayout>

            <TextView
                android:id="@+id/previewEduDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:lineSpacingExtra="1dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionExperience"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EXPERIENCE AND EXTRACURRICULARS"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="12sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#000000" android:layout_marginTop="1dp" />

            <TextView
                android:id="@+id/previewExpName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/previewExpDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:lineSpacingExtra="1dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sectionSkills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SKILLS"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="12sp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#000000" android:layout_marginTop="1dp" />

            <TextView
                android:id="@+id/previewSkills"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>